---
import { cn } from "@demo/lib/utils";
import { Badge } from "@eqtylab/equality";

interface Props {
  label: string;
  list: Array<{ text: string; href: string; deprecated?: boolean }>;
}

const { label, list } = Astro.props;
const currentPath = Astro.url.pathname;

const stripTrailingSlash = (path: string) =>
  path.length > 1 ? path.replace(/\/$/, "") : path;

const isActive = (href: string) =>
  stripTrailingSlash(currentPath) === stripTrailingSlash(href);
---

<div class="space-y-3">
  <h3 class="label">{label}</h3>
  <ul>
    {
      list.map((item) => {
        const active = isActive(item.href);
        return (
          <li>
            <a
              href={item.href}
              class={cn(
                "inline-block w-full border-l px-4 py-1.5 transition-all duration-300",
                active
                  ? "text-text-primary border-text-primary"
                  : "text-text-secondary hover:border-text-primary hover:text-text-primary",
              )}
            >
              <span class="inline-flex items-center gap-2">
                {item.text}
                {item.deprecated && (
                   <Badge variant="warning" className="shrink-0">Deprecated</Badge>
                )}
              </span>
            </a>
          </li>
        );
      })
    }
  </ul>
</div>
